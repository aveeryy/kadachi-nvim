{
    "Controller": {
        "prefix": "air_controller",
        "description": "[Work] API Controller",
        "body": [
            "// Reserved for license",
            "",
            "\"use strict\";",
            "",
            "import Express from \"express\";",
            "import { Controller } from \"../controller\";",
            "import { sendApiError } from \"../../utils/http-utils\";",
            "import { ServiceError } from \"../../utils/service-error\";",
            "",
            "/**",
            " * ${TM_FILENAME_BASE/api-(.*)/${1:/pascalcase}/} API",
            " * @group ${TM_FILENAME_BASE/-/_/g}",
            " */",
            "export class ${TM_FILENAME_BASE/api-(.*)/${1:/pascalcase}/} extends Controller {",
            "    public registerAPI(prefix: string, application: Express.Express) {",
            "        $1",
            "    }",
            "",
            "    $0",
            "}"
        ]
    },
    "Controller endpoint": {
        "prefix": "air_endpoint",
        "description": "[Work] API Endpoint",
        "body": [
            "/**",
            " * $2",
            " * Binding: ${1/(.*)/${1:/pascalcase}/}",
            " * @route $3 /${TM_FILENAME_BASE/api-(.*)/$1/}$4",
            " * @group ${TM_FILENAME_BASE/api-(.*)/$1/}",
            " * $5",
            " */",
            "public async $1(",
            "    request: Express.Request,",
            "    response: Express.Response,",
            ") {",
            "    try {",
            "        $6",
            "    } catch (error) {",
            "        if (error instanceof ServiceError) {",
            "            return sendApiError(",
            "                request,",
            "                response,",
            "                error.status,",
            "                error.code,",
            "                error.message,",
            "            );",
            "        }",
            "",
            "        throw error;",
            "    }",
            "}",
            "$0"
        ]
    },
    "Controller docs typedef": {
        "prefix": "air_docs_typedef",
        "description": "[Work] Documentation: Type definition",
        "body": [
            "/**",
            " * @typedef $1",
            " * $2",
            " */"
        ]
    },
    "Controller docs typedef prop": {
        "prefix": "air_docs_typedef_property",
        "description": "[Work] Documentation: Property",
        "body": "@property {$1} $2 - $3"
    },
    "Controller docs typedef enum prop": {
        "prefix": "air_docs_typedef_enum_property",
        "description": "[Work] Documentation: Property (enum)",
        "body": [
            "@property {enum} $1 - $2",
            "*  - eg: $3"
        ]
    },
    "Controller docs error typedef": {
        "prefix": "air_docs_error_typedef",
        "description": "[Work] Documentation: Error definition",
        "body": [
            "/**",
            " * @typedef $1",
            " * @property {string} code.required - Error code:",
            " * $2",
            " */"
        ]
    },
    "Service error": {
        "prefix": "air_service_error",
        "description": "[Work] Service Error",
        "body": "throw new ServiceError($1, \"$2\");"
    }
}
