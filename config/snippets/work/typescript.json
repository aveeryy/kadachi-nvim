{
    "Controller": {
        "prefix": "air_controller",
        "description": "[Work] API Controller",
        "body": [
            "// Reserved for license",
            "",
            "\"use strict\";",
            "",
            "import Express from \"express\";",
            "import { Controller } from \"../controller\";",
            "import { sendApiError } from \"../../utils/http-utils\";",
            "import { ServiceError } from \"../../utils/service-error\";",
            "",
            "/**",
            " * ${TM_FILENAME_BASE/api-(.*)/${1:/pascalcase}/} API",
            " * @group ${TM_FILENAME_BASE/api-(.*)/${1:/snakecase}/}",
            " */",
            "export class ${TM_FILENAME_BASE/api-(.*)/${1:/pascalcase}/} extends Controller {",
            "    public registerAPI(prefix: string, application: Express.Express) {",
            "        $1",
            "    }",
            "",
            "    $0",
            "}"
        ]
    },
    "Controller endpoint": {
        "prefix": "air_endpoint",
        "description": "[Work] API Endpoint",
        "body": [
            "/**",
            " * $2",
            " * Binding: ${1/(.*)/${1:/pascalcase}/}",
            " * @route $3 /${TM_FILENAME_BASE/api-(.*)/$1/}$4",
            " * @group ${TM_FILENAME_BASE/api-(.*)/${1:/snakecase}/}",
            " * $5",
            " */",
            "public async $1(",
            "    request: Express.Request,",
            "    response: Express.Response,",
            ") {",
            "    try {",
            "        $6",
            "    } catch (error) {",
            "        if (error instanceof ServiceError) {",
            "            return sendApiError(",
            "                request,",
            "                response,",
            "                error.status,",
            "                error.code,",
            "                error.message,",
            "            );",
            "        }",
            "",
            "        throw error;",
            "    }",
            "}",
            "$0"
        ]
    },
    "Controller docs typedef": {
        "prefix": "air_docs_typedef",
        "description": "[Work] Documentation: Type definition",
        "body": [
            "/**",
            " * @typedef $1",
            " * $2",
            " */"
        ]
    },
    "Controller docs typedef prop": {
        "prefix": "air_docs_typedef_property",
        "description": "[Work] Documentation: Property",
        "body": "@property {$1} $2 - $3"
    },
    "Controller docs typedef enum prop": {
        "prefix": "air_docs_typedef_enum_property",
        "description": "[Work] Documentation: Property (enum)",
        "body": [
            "@property {enum} $1 - $2",
            "*  - eg: $3"
        ]
    },
    "Controller docs error typedef": {
        "prefix": "air_docs_error_typedef",
        "description": "[Work] Documentation: Error definition",
        "body": [
            "/**",
            " * @typedef $1",
            " * @property {string} code.required - Error code:",
            " * $2",
            " */"
        ]
    },
    "Service error": {
        "prefix": "air_service_error",
        "description": "[Work] Service Error",
        "body": "throw new ServiceError($1, \"$2\");"
    },
    "[Work] Model": {
        "prefix": "air_model",
        "description": "[Work] Model",
        "body": [
            "// Reserved for license",
            "",
            "\"use strict\";",
            "",
            "import {",
            "    DataModel,",
            "    DataSource,",
            "    DataFinder,",
            "    DataFilter,",
            "    TypedRow,",
            "    enforceType,",
            "} from \"tsbean-orm\";",
            "import { createRandomUID } from \"../utils/text-utils\";",
            "",
            "const DATA_SOURCE = DataSource.DEFAULT;",
            "const TABLE = \"${2:${TM_FILENAME_BASE/-/_/}s}\";",
            "const PRIMARY_KEY = \"${CLIPBOARD/(\\w+):[\\w\\n\\s:;]+/$1/}\";",
            "",
            "export class ${1:${TM_FILENAME_BASE/(.+)/${1:/pascalcase}/}} extends DataModel {",
            "    public static finder = new DataFinder<$1>(",
            "        DATA_SOURCE,",
            "        TABLE,",
            "        PRIMARY_KEY,",
            "        (data: any) => new $1(data),",
            "    );",
            "",
            "    public static async findBy${CLIPBOARD/(\\w+):[\\w\\n\\s:;]+/${1:/pascalcase}/}(${CLIPBOARD/(\\w+):\\s*(\\w+)[\\w\\n\\s:;]+/$1: $2/}): Promise<$1 | null> {",
            "        return await $1.finder.findByKey(${CLIPBOARD/(\\w+):[\\w\\n\\s:;]+/$1/});",
            "    }",
            "",
            "    public static async findAll(): Promise<$1[]> {",
            "        return await $1.finder.find(DataFilter.any());",
            "    }",
            "",
            "    public static async countAll(): Promise<number> {",
            "        return await $1.finder.count(DataFilter.any());",
            "    }",
            "",
            "    public static async create(",
            "        ${CLIPBOARD/.*\\s([\\w]+):\\s*(\\w+);?/$1: $2,/g}",
            "    ): Promise<$1> {",
            "      const ${1/(.+)/${1:/camelcase}/} = new $1({",
            "          ${CLIPBOARD/(\\w+):[\\w\\n\\s:;]+/$1/}: createRandomUID(),",
            "          ${CLIPBOARD/.*\\s([\\w]+):\\s*(\\w+);?/$1,\n/g}",
            "      });",
            "",
            "      await ${1/(.+)/${1:/camelcase}/}.insert();",
            "",
            "      return ${1/(.+)/${1:/camelcase}/};",
            "    };",
            "",
            "    public async update(data: TypedRow<$1>): Promise<void> {",
            "        ${CLIPBOARD/.*\\s([\\w]+):\\s*(\\w+);?/if (data.$1 !== undefined) this.$1 = data.$1;\n/g}",
            "        await this.save();",
            "    }",
            "",
            "    ${CLIPBOARD/([\\w]+):\\s*(\\w+);?/\\/* db-type: db$2 *\\/\npublic $1: $2;\n/g}",
            "    constructor(data: TypedRow<$1>) {",
            "        super(DATA_SOURCE, TABLE, PRIMARY_KEY);",
            "",
            "        ${CLIPBOARD/(\\w+):\\s*(\\w+)[\\w\\n\\s:;]+/this.$1 = enforceType(data.$1, \"${2:/lowcase}\") || createRandomUID();/g}",
            "        ${CLIPBOARD/.*\\s(\\w+):\\s*(\\w+);?/this.$1 = enforceType(data.$1, \"${2:/lowcase}\") || \"\";\n/g}",
            "        this.init();",
            "    }",
            "}"
        ]
    }
}
